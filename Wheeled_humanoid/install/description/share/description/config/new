
    FollowPath:
      plugin: "dwb_core::DWBLocalPlanner"
      debug_trajectory_details: True
      vx_samples: 6
      vy_samples: 0
      vtheta_samples: 8
      sim_time: 1.5
      linear_granularity: 0.05
      angular_granularity: 0.1

      
      min_vel_x: 0.0
      max_vel_x: 0.3
      min_vel_y: 0.0
      max_vel_y: 0.0
      min_vel_theta: -1.0
      max_vel_theta: 1.0

      # Allow zero minimum forward speed to avoid forcing oscillatory motion
      min_speed_xy: 0.0
      min_speed_theta: 0.01
      acc_lim_x: 1.0
      acc_lim_y: 0.0
      acc_lim_theta: 1.0
      decel_lim_x: -1.0
      decel_lim_y: 0.0
      decel_lim_theta: -1.0

      
      # TUNED CRITICS:
      critics: ["RotateToGoal", "Oscillation", "BaseObstacle", "GoalAlign", "PathAlign", "PathDist", "GoalDist"]
      PathDist.scale: 2.0
      GoalDist.scale: 2.0
      PathAlign.scale: 1.5 # Lowered to prevent "path fighting"
      GoalAlign.scale: 1.5 # Lowered to prevent "path fighting"
      BaseObstacle.scale: 0.05 # Increased slightly for safety
      Oscillation.scale: 1.0
      RotateToGoal.scale: 4.0
      RotateToGoal.slowing_factor: 2.0
      RotateToGoal.lookahead_time: 0.8
